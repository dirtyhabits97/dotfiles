{
  "permissions": {
    "defaultMode": "plan"
  },
  "model": "opus[1m]",
  "effortLevel": "xhigh",
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.config/claude/bin/notify.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.config/claude/bin/statusline.sh",
    "padding": 2
  },
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  }
}
